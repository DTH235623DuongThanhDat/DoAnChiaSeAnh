<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Hồ sơ của <%= user.username %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-4">
  <!-- NAVBAR -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary m-0">👤 Hồ sơ: <%= user.username %></h2>
    <div>
      <a href="/" class="btn btn-secondary btn-sm me-2">🏠 Trang chủ</a>
      <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
        <% if (typeof userId !== 'undefined' && userId !== user._id.toString()) { %>
          <a href="/profile" class="btn btn-info btn-sm text-white me-2">👤 Hồ sơ của tôi</a>
        <% } %>
        <a href="/logout" class="btn btn-danger btn-sm">🚪 Đăng xuất</a>
      <% } else { %>
        <a href="/login" class="btn btn-primary btn-sm me-2">🔐 Đăng nhập</a>
        <a href="/register" class="btn btn-success btn-sm">📝 Đăng ký</a>
      <% } %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-12 mb-3">
      <h4>Ảnh đã đăng tải (<%= photos.length %>)</h4>
    </div>
  </div>

  <!-- GRID ẢNH CỦA USER -->
  <div class="row">
    <% if (photos.length === 0) { %>
      <div class="col-12">
        <p class="text-muted">Bạn chưa đăng tải ảnh nào.</p>
      </div>
    <% } else { %>
      <% photos.forEach(photo => { %>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm">
            <a href="/photo/<%= photo._id %>">
              <img src="<%= photo.imageUrl %>" class="card-img-top" alt="<%= photo.title %>">
            </a>
            <div class="card-body text-center">
              <h5><%= photo.title %></h5>
              <% if (typeof userId !== 'undefined' && userId === user._id.toString()) { %>
                <div class="d-flex justify-content-center gap-2">
                  <a href="/edit/<%= photo._id %>" class="btn btn-warning btn-sm">Sửa</a>
                  <form action="/delete/<%= photo._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-danger btn-sm">Xóa</button>
                  </form>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

</div>

</body>
</html>
