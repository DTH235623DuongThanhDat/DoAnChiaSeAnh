<div class="container mt-5">
  <h2>Chỉnh sửa ảnh</h2>
  <form action="/edit/<%= photo._id %>" method="POST" enctype="multipart/form-data">
    <div class="mb-3">
      <label>Tiêu đề mới:</label>
      <input type="text" name="title" value="<%= photo.title %>" class="form-control" required>
    </div>
    
    <div class="mb-3">
      <p>Ảnh hiện tại:</p>
      <img src="<%= photo.imageUrl %>" width="200" class="mb-2">
      <label>Thay ảnh mới (để trống nếu không muốn đổi):</label>
      <input type="file" name="image" class="form-control">
    </div>

    <button class="btn btn-primary">Lưu thay đổi</button>
    <a href="/" class="btn btn-secondary">Hủy</a>
  </form>
</div>